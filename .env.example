# =============================================================
# CallCenter Ticket Management System — Environment Variables
# =============================================================

# --- Application ---
APP_NAME=callcenter
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-min-32-chars!!
API_V1_PREFIX=/api/v1

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://callcenter:callcenter_pass@postgres:5432/callcenter
DATABASE_ECHO=false

# --- Redis ---
REDIS_URL=redis://:callcenter_pass@redis:6379/0
CELERY_BROKER_URL=redis://:callcenter_pass@redis:6379/1
CELERY_RESULT_BACKEND=redis://:callcenter_pass@redis:6379/2

# --- JWT ---
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
# Fallback for dev (HS256)
JWT_SECRET=dev-secret-change-in-production!!
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Config Encryption (AES-256) ---
CONFIG_ENCRYPTION_KEY=change-me-32-char-encryption-key!

# --- Microsoft Graph (Outlook) ---
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_WEBHOOK_SECRET=change-me-webhook-secret

# --- Jira Cloud ---
JIRA_SITE_URL=
JIRA_API_EMAIL=
JIRA_API_TOKEN=
JIRA_WEBHOOK_SECRET=

# --- LDAP / Active Directory ---
LDAP_SERVER_URL=ldaps://ad.company.com:636
LDAP_BIND_DN=CN=svc_callcenter,OU=ServiceAccounts,DC=company,DC=com
LDAP_BIND_PASSWORD=
LDAP_BASE_DN=DC=company,DC=com
LDAP_USER_SEARCH_FILTER=(&(objectClass=user)(sAMAccountName={username}))
LDAP_GROUP_SEARCH_FILTER=(&(objectClass=group)(member={user_dn}))

# --- Voice Pipeline ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- LiveKit ---
LIVEKIT_URL=ws://livekit-server:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# --- MinIO (S3-compatible storage) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_ATTACHMENTS=attachments
MINIO_BUCKET_RECORDINGS=recordings
MINIO_USE_SSL=false

# --- Internal Service Key ---
INTERNAL_SERVICE_KEY=internal_callcenter_2026

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
