{
  "uid": "symvera-overview",
  "title": "Symvera Platform Overview",
  "tags": ["symvera"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "title": "Servis Durumu", "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "up", "legendFormat": "{{job}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "mappings": [{ "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }], "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } } }
    },
    {
      "id": 2, "title": "Aktif Servis Sayısı", "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "count(up == 1)", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 4 }, { "color": "green", "value": 6 }] } } }
    },
    {
      "id": 3, "title": "HTTP İstek Oranı (req/s)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{ "expr": "sum(rate(http_requests_total[5m])) by (job)", "legendFormat": "{{job}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 4, "title": "Hata Oranı (5xx)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{ "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) by (job)", "legendFormat": "{{job}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "red" } } }
    },
    {
      "id": 5, "title": "Yanıt Süresi p95 (ms)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (job, le)) * 1000", "legendFormat": "{{job}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 6, "title": "Bellek Kullanımı (MB)", "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [{ "expr": "symvera_nodejs_heap_size_used_bytes / 1024 / 1024", "legendFormat": "{{job}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "decmbytes" } }
    }
  ]
}
